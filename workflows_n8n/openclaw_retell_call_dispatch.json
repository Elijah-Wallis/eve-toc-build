    {
      "parameters": {
        "functionCode": "const abortOnMissing = String($node[\"Webhook Trigger\"].json.abort_on_missing_promo_fields ?? $node[\"Config\"].json.ABORT_ON_MISSING_PROMO_FIELDS ?? '1').toLowerCase() !== '0';\nconst missing = [];\nfor (const item of items) {\n  const lead = item.json || {};\n  const missingKeys = [];\n  if (!String(lead.current_promo_service || '').trim()) missingKeys.push('current_promo_service');\n  if (!String(lead.promo_details || '').trim()) missingKeys.push('promo_details');\n  if (!String(lead.opening_time || '').trim()) missingKeys.push('opening_time');\n  if (missingKeys.length) {\n    const row = { lead_id: lead.id || null, business_name: lead.business_name || null, missing_keys: missingKeys };\n    missing.push(row);\n    console.log(`[dispatch:promo-missing] ${JSON.stringify(row)}`);\n  }\n}\nif (missing.length && abortOnMissing) {\n  throw new Error(`prebatch_validation_failed_missing_promo_fields=${JSON.stringify(missing)}`);\n}\nreturn items;"
