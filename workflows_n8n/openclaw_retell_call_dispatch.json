    {
      "parameters": {
        "functionCode": "const lead = $node[\"Filter Leads\"].json || {};\nconst cfg = $node[\"Config\"].json || {};\nconst isB2C = !!lead.decision_maker_confirmed;\nlet agentType = isB2C ? 'B2C' : 'B2B';\nlet agentId = isB2C ? cfg.RETELL_AGENT_B2C_ID : cfg.RETELL_AGENT_B2B_ID;\nif (!isB2C) {\n  const override = String($node[\"Webhook Trigger\"].json.b2b_agent_override_id || '').trim();\n  const mode = String(cfg.OPENCLAW_B2B_CANARY_MODE || 'off').toLowerCase();\n  const v6Id = String(cfg.RETELL_AGENT_B2B_V6_ID || '').trim();\n  const source = String(lead.source || '');\n  const sourceRegexRaw = String(cfg.OPENCLAW_B2B_CANARY_SOURCE_REGEX || '^tx-medspa-');\n  let sourceMatch = false;\n  try { sourceMatch = new RegExp(sourceRegexRaw).test(source); } catch (e) { sourceMatch = source.startsWith('tx-medspa-'); }\n  const samplePct = Math.max(0, Math.min(100, Number(cfg.OPENCLAW_B2B_CANARY_SAMPLE_PCT || 50)));\n  const hashSeed = String(lead.id || lead.phone || source || '');\n  const hash = [...hashSeed].reduce((acc, ch) => acc + ch.charCodeAt(0), 0) % 100;\n  const inSample = hash < samplePct;\n  if (override) {\n    agentId = override;\n    agentType = 'B2B_OVERRIDE';\n  } else if (mode === 'force_v6' && v6Id) {\n    agentId = v6Id;\n    agentType = 'B2B_V6';\n  } else if (mode === 'canary' && v6Id && sourceMatch && inSample) {\n    agentId = v6Id;\n    agentType = 'B2B_V6';\n  }\n}\nconst fromNumber = $node[\"Config\"].json.RETELL_FROM_NUMBER;\nif (!fromNumber || !lead.phone) return [];\nconst promoServiceRaw = String(lead.current_promo_service || '').trim();\nconst promoDetailsRaw = String(lead.promo_details || '').trim();\nconst openingTimeRaw = String(lead.opening_time || '').trim();\nconst promoService = promoServiceRaw || 'your current promotion';\nconst promoDetails = promoDetailsRaw || 'your featured service';\nconst openingTime = openingTimeRaw || 'during your listed hours';\nif (!promoServiceRaw) console.log(`[dispatch:null-var] lead=${lead.id || 'unknown'} key=current_promo_service fallback=${promoService}`);\nif (!promoDetailsRaw) console.log(`[dispatch:null-var] lead=${lead.id || 'unknown'} key=promo_details fallback=${promoDetails}`);\nif (!openingTimeRaw) console.log(`[dispatch:null-var] lead=${lead.id || 'unknown'} key=opening_time fallback=${openingTime}`);\nreturn [{ json: {\n  lead,\n  agent_id: agentId,\n  agent_type: agentType,\n  from_number: fromNumber,\n  request_body: {\n    from_number: fromNumber,\n    to_number: lead.phone,\n    override_agent_id: agentId,\n    retell_llm_dynamic_variables: {\n      business_name: lead.business_name || '',\n      city: lead.city || '',\n      state: lead.state || '',\n      website: lead.website || '',\n      category: Array.isArray(lead.categories) ? (lead.categories[0] || '') : '',\n      rating: String(lead.rating ?? ''),\n      reviews_count: String(lead.reviews_count ?? ''),\n      touch_count: String(lead.touch_count ?? 0),\n      lead_id: lead.id || '',\n      source: lead.source || '',\n      current_promo_service: promoService,\n      promo_service: promoService,\n      promo_details: promoDetails,\n      opening_time: openingTime,\n      b2b_agent_variant: agentType,\n      canary_mode: String(cfg.OPENCLAW_B2B_CANARY_MODE || 'off')\n    }\n  }\n} }];"
      },
