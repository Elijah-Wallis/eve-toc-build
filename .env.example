# OpenClaw Docker runtime
OPENCLAW_PROFILE=eve
OPENCLAW_GATEWAY_PORT=19001
OPENCLAW_GATEWAY_BIND=lan

# Required: set a strong token (used by CLI + cron)
OPENCLAW_GATEWAY_TOKEN=

# Choose one model provider
OPENROUTER_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Optional: model routing knobs
# OPENCLAW_DEFAULT_MODEL=openrouter/moonshotai/kimi-k2.5
# OPENROUTER_MODEL_PRIMARY=openrouter/moonshotai/kimi-k2.5
# OPENROUTER_MODEL_FALLBACK=openrouter/moonshotai/kimi-k2
# OPENCLAW_FALLBACK_MODELS=openrouter/... , openrouter/...
# OPENCLAW_MODEL_ALIASES=fast:openrouter/...,deep:openrouter/...

# Optional: Telegram updates
OPENCLAW_TELEGRAM_BOT_TOKEN=
OPENCLAW_TELEGRAM_CHAT_ID=
OPENCLAW_TELEGRAM_USER_ID=
OPENCLAW_TELEGRAM_INGRESS_OWNER=custom_listener

# Runtime APIs
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
N8N_PUBLIC_WEBHOOK_BASE=
N8N_API_BASE=https://elijah-wallis.app.n8n.cloud/api/v1
N8N_API_KEY=
OPENCLAW_N8N_BINDING_MODE=env
OPENCLAW_ALLOW_LITERAL_WORKFLOW_SECRETS=0

# n8n MCP (Retell wrapper path)
N8N_MCP_URL=https://elijah-wallis.app.n8n.cloud/mcp-server/http
N8N_MCP_AUTH_HEADER=Authorization
N8N_MCP_TOKEN=
N8N_MCP_ACCESS_TOKEN=
N8N_OAUTH_SERVER_URL=

# Revenue channels
RETELL_AI_KEY=
RETELL_API_BASE=https://api.retellai.com
RETELL_LLM_WEBSOCKET_URL=
RETELL_FROM_NUMBER=
RETELL_AGENT_B2B_ID=
RETELL_AGENT_B2B_V6_ID=
RETELL_AGENT_B2C_ID=
B2C_CLINIC_NAME=Your MedSpa
B2C_TIMEZONE=America/Chicago
B2C_OPEN_HOUR=9
B2C_CLOSE_HOUR=18
B2C_CREDENTIALS_BLURB=Board-certified clinical team and medical director oversight
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
EVIDENCE_EMAIL_PROVIDER_URL=
EVIDENCE_EMAIL_API_KEY=
EVIDENCE_EMAIL_FROM=

# Revenue intelligence
APIFY_API_TOKEN=
APIFY_ACTOR_ID=
# Clay/Xano deprecated. Intelligence path is Apify + Supabase.

# MCP daemon ports
APIFY_MCP_PORT=7081
SUPABASE_MCP_PORT=7082
RETELL_MCP_PORT=7083
TWILIO_MCP_PORT=7084
INTELLIGENCE_MCP_PORT=7085
CLOUDFLARE_MCP_PORT=7086

# Cloudflare (for named tunnel + DNS automation via cloudflare_mcp)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
CF_TUNNEL_NAME=retell-brain
CF_TUNNEL_HOSTNAME=

# Launch hardening
OPENCLAW_CAPTURE_TRAFFIC=0
OPENCLAW_SECRETS_SOURCE=file
OPENCLAW_ALLOW_ENV_SECRET_FALLBACK=0
OPENCLAW_IMMUTABLE_LOGS=1
OPENCLAW_IMMUTABLE_STRICT=0
OPENCLAW_IMMUTABLE_FSYNC_EVERY=1

# Runtime stability envelope
OPENCLAW_RUNTIME_STABILITY_ENVELOPE=1
OPENCLAW_STEP_MAX_RETRIES=2
OPENCLAW_STEP_BACKOFF_MS=250
OPENCLAW_FATAL_ERROR_BUDGET_PER_HOUR=50

# Role split (all|scheduler|worker)
OPENCLAW_RUNTIME_ROLE=all
OPENCLAW_TASK_BATCH_SIZE=200

# Throughput controls (keep Twilio at 1 msg/sec to avoid account flags)
RATE_LIMIT_SEND_EVIDENCE_30M=1800
TWILIO_SMS_MAX_PER_SECOND=1

# V6 B2B canary controls
OPENCLAW_B2B_CANARY_MODE=off
OPENCLAW_B2B_CANARY_SOURCE_REGEX=^tx-medspa-
OPENCLAW_B2B_CANARY_SAMPLE_PCT=50
